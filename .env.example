# Payload CMS — https://payloadcms.com/docs
PAYLOAD_SECRET=replace-with-a-long-random-secret
DATABASE_URI=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob — added when Blob storage is connected in Vercel
BLOB_READ_WRITE_TOKEN=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Where contact and newsletter notifications are delivered
CONTACT_TO_EMAIL= <your email>

# Must use a verified domain in production (Resend dashboard → Domains)
# For local testing before domain setup, Resend allows onboarding@resend.dev
CONTACT_FROM_EMAIL=<your email>

# Public site URL — used for logo in notification emails (optional locally)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
